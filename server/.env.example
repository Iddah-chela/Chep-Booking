# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
CLIENT_URL=https://patakeja.co.ke

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/patakeja?retryWrites=true&w=majority

# ── Clerk (get from clerk.com → your app → API Keys) ─────────────────────────
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── Cloudinary (get from cloudinary.com → Dashboard) ─────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxx

# ── Nodemailer / Gmail SMTP ───────────────────────────────────────────────────
EMAIL_USER=your@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx    # Gmail App Password (not your account password)

# ── IntaSend Payments ─────────────────────────────────────────────────────────
# Get from intasend.com → Settings → API Keys
INTASEND_PUBLIC_KEY=ISPubKey_live_xxxxxxxxxxxxxxxxxxxx
INTASEND_SECRET_KEY=ISSecretKey_live_xxxxxxxxxxxxxxxxxxxx

# ── Web Push / VAPID ─────────────────────────────────────────────────────────
# Generate once: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
