# ── Backend URL ───────────────────────────────────────────────────────────────
# Local dev:
VITE_BACKEND_URL=http://localhost:3000
# Production (your Railway/Render server URL):
# VITE_BACKEND_URL=https://your-server.railway.app

# ── Clerk (use publishable key — safe to expose) ──────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ── Currency ──────────────────────────────────────────────────────────────────
VITE_CURRENCY=Ksh

# ── Web Push (same VAPID public key as server) ────────────────────────────────
VITE_VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
